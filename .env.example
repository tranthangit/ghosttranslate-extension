# Copy this file to .env.local and fill in your own values.
# .env.local is git-ignored so these never appear in the public source.

# URL of your Cloudflare Worker that proxies Workers AI.
VITE_WORKER_ENDPOINT=https://your-worker.example.com

# Default AI model id (the worker may override this server-side).
VITE_DEFAULT_MODEL=your-model-id

# Optional shared token sent as X-GT-App (leave empty to skip).
# VITE_APP_TOKEN=
